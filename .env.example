# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# mimik AI Foundation endpoint (OpenAI-compatible)
MIMIK_ENDPOINT=http://localhost:8083/mimik-ai/openai/v1

# Exact model name as reported by your mimik runtime
MODEL_NAME=your-model-name-here

# ChromaDB persistent storage path
CHROMA_PATH=./chroma_db

# ChromaDB collection name
CHROMA_COLLECTION=istqb

# Number of chunks to retrieve per query
TOP_K=4

# Chunk size in words (target range 500–800)
CHUNK_SIZE=500

# Word overlap between consecutive chunks
CHUNK_OVERLAP=100

# Sentence-transformers model for embeddings
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Embedding batch size during ingestion
EMBED_BATCH_SIZE=32

# LLM request timeout in seconds
LLM_TIMEOUT=30

# Path to the prompts directory (leave unset to use the built-in default)
# PROMPTS_DIR=./qa_agent/prompts
